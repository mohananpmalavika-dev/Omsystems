{
  "name": "sentinel-grid",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "dashboard",
    "edge-agent",
    "media-gateway"
  ],
  "description": "Hybrid CCTV control plane for multi-branch organizations",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrate": "node scripts/run-migrations.mjs",
    "migrate:status": "node scripts/run-migrations.mjs status",
    "migrate:test": "node scripts/test-migrations-local.mjs",
    "edge:dev": "npm run dev --workspace @sentinel/edge-agent",
    "edge:typecheck": "npm run typecheck --workspace @sentinel/edge-agent",
    "edge:test": "npm run test --workspace @sentinel/edge-agent",
    "media:dev": "npm run dev --workspace @sentinel/media-gateway",
    "media:typecheck": "npm run typecheck --workspace @sentinel/media-gateway",
    "media:test": "npm run test --workspace @sentinel/media-gateway",
    "recording:dev": "npm run dev --workspace @sentinel/recording-engine",
    "recording:typecheck": "npm run typecheck --workspace @sentinel/recording-engine",
    "dashboard:dev": "npm run dev --workspace @sentinel/dashboard",
    "dashboard:typecheck": "npm run typecheck --workspace @sentinel/dashboard",
    "dashboard:build": "npm run build --workspace @sentinel/dashboard"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "fastify": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
