HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
AUTH_MODE=development
DATABASE_URL=postgresql://sentinel:local-development-only@localhost:5432/sentinel
MEDIA_GATEWAY_SHARED_KEY=development-media-gateway-key-change-me
RECORDING_ENGINE_URL=http://localhost:8091
RECORDING_ENGINE_SHARED_KEY=development-recording-engine-key-change-me
# The same JSON secret-reference map is supplied only to media/recording workers.
STREAM_SECRETS_JSON={}

# ============================================================================
# Notification Configuration (for Maintenance Alerts)
# ============================================================================

# Email Provider (sendgrid, ses, or smtp)
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=notifications@yourdomain.com

# SendGrid Configuration
# EMAIL_API_KEY=SG.your_sendgrid_api_key

# AWS SES Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret

# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# SMS Provider (twilio, sns, or custom)
# SMS_PROVIDER=twilio
# SMS_FROM=+1234567890

# Twilio Configuration
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token

# Custom SMS Gateway
# SMS_API_URL=https://sms-gateway.example.com/send
# SMS_API_KEY=your_api_key

# Webhook Configuration (comma-separated URLs)
# WEBHOOK_URLS=https://your-domain.com/webhook,https://backup-webhook.com/alerts
# WEBHOOK_RETRY_ATTEMPTS=3
# WEBHOOK_TIMEOUT_MS=10000
# WEBHOOK_HEADERS={"Authorization":"Bearer your_token"}
